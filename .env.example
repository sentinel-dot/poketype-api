# Server
# Default port is 4000 so it does not conflict with Next.js (default 3000).
PORT=4000

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# MySQL / MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=dev
DB_PASSWORD=
DB_NAME=poketype

# LiveKit (optional — service degrades gracefully without these)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
